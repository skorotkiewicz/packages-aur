post_install() {
  systemd-sysusers
  systemctl daemon-reload
}

post_upgrade() {
  systemd-sysusers
  systemctl daemon-reload
}

pre_upgrade() {
  systemctl stop loreserver.service 2>/dev/null || true
}

pre_remove() {
  systemctl stop loreserver.service 2>/dev/null || true
}

post_remove() {
  systemctl daemon-reload
}
